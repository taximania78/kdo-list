# Copiez ce fichier en .env.local et renseignez vos propres valeurs.

#GENERAL
NODE_ENV=development
URL_CONNECTION=http://localhost:3000
NEXT_PUBLIC_THEME=christmas
DEBUG=true

#API
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

#JWT
# Générer une valeur forte : openssl rand -hex 32
SECRET_KEY=change-me-with-a-strong-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

#DATABASE
DATABASE_USER=admin
DATABASE_PASSWORD=change-me
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=kdo

#DEPLOIEMENT (optionnel, utilisé par docker-compose/Traefik)
APP_DOMAIN=example.com
